{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": ["FromLogContext"]
  },
  "AllowedHosts": "*",
  "Outbox": {
    "BatchSize": 50,
    "MaxRetries": 3,
    "FallbackPollInterval": "00:00:30"
  }
}
